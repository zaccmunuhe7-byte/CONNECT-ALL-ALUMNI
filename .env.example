NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
CLIENT_ORIGINS=http://localhost:5173,http://your-lan-ip:5173
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/connect_alumni
JWT_ACCESS_SECRET=replace-with-32-byte-random-secret
JWT_REFRESH_SECRET=replace-with-another-32-byte-random-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
UPLOAD_DIR=/absolute/path/to/CONNECT_ALUMNI/uploads
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@connectalumni.local
